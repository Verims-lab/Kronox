{
  "name": "UserJokerInventory",
  "type": "object",
  "description": "User-owned joker balance rows. One logical row should exist per user_email + joker_type. user_email is the lowercased email for registered users or the internal guest:<g_owner_key> key for token-proven completed guests where a backend grant path supports them. Base44/platform index contract: user_email for fast profile loads; user_email + joker_type as the logical unique key. Until platform unique/index proof exists, ensureUserJokerInventory dedupes rows and purchase/spend functions filter by user_email + joker_type before update/create. Balances are initialized by ensureUserJokerInventory, read by Profile Joker \u00c7antas\u0131, spent by Solo through spendUserJoker, purchased through Ma\u011faza, and may be granted by Daily Wheel V2.",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Lowercased owner email for registered users, or internal guest player key guest:<g_owner_key> for token-proven completed guest Daily Wheel grants. Hot lookup field for Profile/Solo/Market inventory reads."
    },
    "joker_type": {
      "type": "string",
      "enum": [
        "mistake_shield",
        "card_swap",
        "time_freeze"
      ],
      "description": "Stable internal joker type. Combined with user_email as the logical unique balance key."
    },
    "quantity": {
      "type": "number",
      "minimum": 0,
      "description": "Current non-negative balance for this joker type."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the inventory row was created."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the balance was last reconciled."
    },
    "last_transaction_id": {
      "type": "string",
      "description": "Latest JokerTransaction id that established this balance, when available."
    },
    "metadata": {
      "type": "object",
      "description": "Debug-safe metadata. Must not contain secrets or private profile data."
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional free-text description for this joker inventory row (up to 1000 characters)."
    }
  },
  "required": [
    "user_email",
    "joker_type",
    "quantity"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
