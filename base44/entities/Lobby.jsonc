{
  "name": "Lobby",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "6-character unique lobby code"
    },
    "host_email": {
      "type": "string",
      "description": "Email of the lobby host"
    },
    "host_name": {
      "type": "string",
      "description": "Display name of the host"
    },
    "players": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "ready": {
            "type": "boolean"
          },
          "cards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "year": {
                  "type": "number"
                },
                "question": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "media_url": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "description": "List of players in the lobby"
    },
    "status": {
      "type": "string",
      "enum": [
        "waiting",
        "starting",
        "in_game",
        "finished",
        "cancelled",
        "expired"
      ],
      "default": "waiting"
    },
    "winner": {
      "type": "string",
      "description": "Name of the winning player"
    },
    "winner_email": {
      "type": "string",
      "description": "Email of the winning player, written with status=finished for local win/loss perspective."
    },
    "state_revision": {
      "type": "number",
      "description": "Monotonic multiplayer state revision used by sync/merge guards."
    },
    "category": {
      "type": "string",
      "enum": [
        "karisik",
        "tarih",
        "bilim",
        "spor",
        "sanat"
      ],
      "default": "karisik",
      "description": "Legacy single-category field. Kept for backward compatibility with old lobbies. New lobbies should prefer selected_category_ids (Codex091)."
    },
    "selected_category_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Codex091 \u2014 stable Online category ids selected by the host (flashback, kult, viral, arena, level_up, chronicle). When present and non-empty, startLobbyGame uses these to filter the question pool. When absent or empty, startLobbyGame falls back to the legacy `category` field (old lobbies keep working)."
    },
    "year_start": {
      "type": "number",
      "default": 1900
    },
    "year_end": {
      "type": "number",
      "default": 2020
    },
    "turn_duration": {
      "type": "number",
      "default": 60,
      "description": "Seconds per turn"
    },
    "win_card_count": {
      "type": "number",
      "default": 10,
      "description": "Number of cards needed to win"
    },
    "current_player_index": {
      "type": "number",
      "default": 0,
      "description": "Index of the player whose turn it is"
    },
    "current_question_id": {
      "type": "string",
      "description": "ID of the current question shown to all players"
    },
    "used_question_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of already used question IDs"
    },
    "max_players": {
      "type": "number",
      "description": "Intended total number of players for this lobby (2, 3 or 4). Informational metadata."
    },
    "invited_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Lowercased emails of friends invited by the host at creation time."
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the lobby transitions into active gameplay."
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the lobby/game is completed."
    },
    "cancelled_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when a waiting lobby is cancelled/stale-retained."
    },
    "last_activity_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp for lobby activity/cleanup decisions. Existing rows may rely on updated_date fallback."
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional stale-waiting expiry timestamp. Cleanup helpers mark stale waiting lobbies instead of deleting them."
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional free-text description for this lobby (up to 1000 characters)."
    }
  },
  "required": [
    "code",
    "host_email"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.host_email": "{{user.email}}"
        },
        {
          "data.players.email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.host_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.host_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}